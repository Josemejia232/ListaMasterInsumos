{
  "name": "listamasterinsumos",
  "version": "1.2.0",
  "private": true,
  "description": "API para scrapeo de insumos de construccion desde Google Sheets",
  "scripts": {
    "dev": "copy /Y config\\.env.develop .env >nul && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "start": "uvicorn app.main:app --host 0.0.0.0 --port %PORT% --workers 2 --timeout-keep-alive 30 --limit-concurrency 100",
    "dev:unix": "cp -f config/.env.develop .env && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "start:unix": "cp -f config/.env.production .env && uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000} --workers 2 --timeout-keep-alive 30 --limit-concurrency 100",
    "daily": "python -m app.daily"
  }
}
